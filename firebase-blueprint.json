{
  "entities": {
    "Agency": {
      "title": "Agency",
      "description": "A travel agency tenant in the multi-tenant system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logo": { "type": "string" },
        "subscription": { "type": "string", "enum": ["free", "pro", "enterprise"] },
        "settings": {
          "type": "object",
          "properties": {
            "theme": { "type": "string", "enum": ["light", "dark", "custom"] },
            "primaryColor": { "type": "string" },
            "webhookUrl": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "subscription"]
    },
    "User": {
      "title": "User",
      "description": "System user with role-based access control and CRM data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "agencyId": { "type": "string", "description": "ID of the agency this user belongs to" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["super_admin", "admin", "agent", "accountant", "support", "client"] },
        "photoURL": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "loyaltyPoints": { "type": "integer" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "agencyId", "email", "role"]
    },
    "Package": {
      "title": "Travel Package",
      "description": "A travel destination package offered by Fiezta.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agencyId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "destination": { "type": "string" },
        "price": { "type": "number" },
        "duration": { "type": "string" },
        "imageUrl": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["agencyId", "title", "destination", "price"]
    },
    "Booking": {
      "title": "Booking Request",
      "description": "A client booking or service request.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agencyId": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "packageId": { "type": "string" },
        "packageName": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "pending", "processing", "approved", "completed", "cancelled"] },
        "travelDate": { "type": "string", "format": "date" },
        "totalAmount": { "type": "number" },
        "paidAmount": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "partial", "paid", "refunded"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["agencyId", "clientId", "status", "createdAt"]
    },
    "SocialPost": {
      "title": "Social Media Post",
      "description": "A scheduled social media post.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agencyId": { "type": "string" },
        "content": { "type": "string" },
        "platforms": { "type": "array", "items": { "type": "string" } },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["scheduled", "published", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["agencyId", "content", "platforms", "scheduledAt"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Security audit log for system actions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agencyId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "resourceType": { "type": "string" },
        "resourceId": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["agencyId", "userId", "action", "timestamp"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount coupon for bookings.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agencyId": { "type": "string" },
        "code": { "type": "string" },
        "discountType": { "type": "string", "enum": ["percentage", "fixed"] },
        "discountValue": { "type": "number" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" }
      },
      "required": ["agencyId", "code", "discountType", "discountValue"]
    },
    "Role": {
      "title": "User Role",
      "description": "Customizable user role with specific permissions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agencyId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "isSystem": { "type": "boolean", "description": "If true, this role cannot be deleted" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["agencyId", "name", "permissions"]
    },
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global site configuration for an agency.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agencyId": { "type": "string" },
        "siteName": { "type": "string" },
        "siteDescription": { "type": "string" },
        "logoUrl": { "type": "string" },
        "faviconUrl": { "type": "string" },
        "contactEmail": { "type": "string", "format": "email" },
        "contactPhone": { "type": "string" },
        "address": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["agencyId", "siteName"]
    },
    "CustomForm": {
      "title": "Custom Form",
      "description": "A custom lead capture form.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agencyId": { "type": "string" },
        "title": { "type": "string" },
        "fields": { "type": "array", "items": { "type": "object" } },
        "submitButtonText": { "type": "string" },
        "successMessage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["agencyId", "title"]
    },
    "PopupCampaign": {
      "title": "Popup Campaign",
      "description": "A dynamic popup campaign for marketing.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agencyId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["modal", "slide-in", "bar"] },
        "trigger": { "type": "string", "enum": ["exit-intent", "scroll", "time-on-page"] },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["agencyId", "title", "type", "trigger"]
    },
    "Service": {
      "title": "Service",
      "description": "Offered service like musical entertainment, travel, rentals.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agencyId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["entertainment", "travel", "rental", "tour", "other"] },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "Review": {
      "title": "Review",
      "description": "Customer testimonials.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agencyId": { "type": "string" },
        "customerName": { "type": "string" },
        "rating": { "type": "integer" },
        "content": { "type": "string" },
        "photoUrl": { "type": "string" },
        "date": { "type": "string", "format": "date" }
      }
    },
    "FAQ": {
      "title": "FAQ",
      "description": "Frequently asked questions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agencyId": { "type": "string" },
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "order": { "type": "integer" }
      }
    },
    "Page": {
      "title": "Page",
      "description": "Dynamic CMS page.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agencyId": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "content": { "type": "string" },
        "blocks": { "type": "array", "items": { "type": "object" } },
        "status": { "type": "string", "enum": ["publish", "draft"] }
      }
    },
    "Menu": {
      "title": "Menu",
      "description": "Navigational menu.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agencyId": { "type": "string" },
        "title": { "type": "string" },
        "location": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "isActive": { "type": "boolean" }
      }
    },
    "Invention": {
      "title": "Invention",
      "description": "Patented project seeking licensing.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agencyId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "content": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "draft"] }
      }
    },
    "Accommodation": {
      "title": "Accommodation",
      "description": "Hotel or stay option.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agencyId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "location": { "type": "string" },
        "pricePerNight": { "type": "number" }
      }
    },
    "Transport": {
      "title": "Transport",
      "description": "Car, flight, or boat option.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agencyId": { "type": "string" },
        "provider": { "type": "string" },
        "type": { "type": "string" },
        "model": { "type": "string" },
        "price": { "type": "number" }
      }
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Financial document for a booking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agencyId": { "type": "string" },
        "bookingId": { "type": "string" },
        "clientId": { "type": "string" },
        "amount": { "type": "number" },
        "dueDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["unpaid", "paid", "overdue"] }
      }
    },
    "TravelDocument": {
      "title": "Travel Document",
      "description": "Visa, passport, or tickets.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agencyId": { "type": "string" },
        "bookingId": { "type": "string" },
        "clientId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "fileUrl": { "type": "string" }
      }
    },
    "Itinerary": {
      "title": "Itinerary",
      "description": "Personalized travel plan.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agencyId": { "type": "string" },
        "bookingId": { "type": "string" },
        "clientId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "CalendarEvent": {
      "title": "Calendar Event",
      "description": "An event in the agency calendar.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agencyId": { "type": "string" },
        "title": { "type": "string" },
        "start": { "type": "string", "format": "date-time" },
        "end": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["booking", "staff_schedule", "meeting", "other"] },
        "color": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/agencies/{id}": { "schema": "Agency", "description": "Agencies." },
    "/users/{uid}": { "schema": "User", "description": "User profiles." },
    "/packages/{packageId}": { "schema": "Package", "description": "Travel packages." },
    "/bookings/{bookingId}": { "schema": "Booking", "description": "Bookings." },
    "/social_posts/{id}": { "schema": "SocialPost", "description": "Social media posts." },
    "/audit_logs/{id}": { "schema": "AuditLog", "description": "Audit logs." },
    "/coupons/{id}": { "schema": "Coupon", "description": "Coupons." },
    "/roles/{roleId}": { "schema": "Role", "description": "Custom user roles." },
    "/site_settings/{id}": { "schema": "SiteSettings", "description": "Site-wide settings." },
    "/custom_forms/{id}": { "schema": "CustomForm", "description": "Custom forms." },
    "/popup_campaigns/{id}": { "schema": "PopupCampaign", "description": "Popup campaigns." },
    "/services/{id}": { "schema": "Service", "description": "Services." },
    "/reviews/{id}": { "schema": "Review", "description": "Reviews." },
    "/faqs/{id}": { "schema": "FAQ", "description": "FAQs." },
    "/pages/{id}": { "schema": "Page", "description": "CMS Pages." },
    "/menus/{id}": { "schema": "Menu", "description": "Menus." },
    "/inventions/{id}": { "schema": "Invention", "description": "Inventions." },
    "/accommodations/{id}": { "schema": "Accommodation", "description": "Accommodations." },
    "/transport/{id}": { "schema": "Transport", "description": "Transports." },
    "/invoices/{id}": { "schema": "Invoice", "description": "Invoices." },
    "/documents/{id}": { "schema": "TravelDocument", "description": "Travel documents." },
    "/itineraries/{id}": { "schema": "Itinerary", "description": "Itineraries." },
    "/calendar_events/{id}": { "schema": "CalendarEvent", "description": "Calendar events." }
  }
}
