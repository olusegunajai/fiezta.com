rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // 2. Global Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Auth records lookup
    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function hasUserData(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function myAgencyId() {
      return hasUserData(request.auth.uid) ? getUserData(request.auth.uid).agencyId : 'NONE';
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "dbest4real2009@gmail.com" || 
        request.auth.uid == "LfqZzTIauzcfHSs6UYPxwkKCaZ42" ||
        (hasUserData(request.auth.uid) && getUserData(request.auth.uid).role == 'super_admin')
      );
    }

    function isAgencyAdmin(agencyId) {
      return isSignedIn() && hasUserData(request.auth.uid) && 
             getUserData(request.auth.uid).agencyId == agencyId &&
             getUserData(request.auth.uid).role == 'admin';
    }

    function isStaff(agencyId) {
      return isSignedIn() && hasUserData(request.auth.uid) && 
             getUserData(request.auth.uid).agencyId == agencyId &&
             getUserData(request.auth.uid).role in ['admin', 'agent', 'accountant', 'support'];
    }

    // ===============================================================
    // 3. Entity Validation Blueprints
    // ===============================================================

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.agencyId is string && data.agencyId.size() > 0 &&
             data.email is string && data.email.size() < 255 &&
             data.role in ['super_admin', 'admin', 'agent', 'accountant', 'support', 'client'] &&
             (!('loyaltyPoints' in data) || data.loyaltyPoints is int);
    }

    function isValidBooking(data) {
      return data.agencyId is string && data.agencyId.size() > 0 &&
             data.clientId is string && data.clientId.size() > 0 &&
             data.status in ['draft', 'pending', 'confirmed', 'completed', 'cancelled'] &&
             data.totalAmount is number &&
             data.createdAt is string;
    }

    function isValidPackage(data) {
      return data.agencyId is string && data.agencyId.size() > 0 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.price is number && data.price >= 0;
    }

    function isValidRole(data) {
      return data.agencyId is string && data.agencyId.size() > 0 &&
             data.name is string && data.name.size() > 0 &&
             data.permissions is list && data.permissions.size() < 100;
    }

    // ===============================================================
    // 4. Match Blocks (Fortress Grade)
    // ===============================================================

    match /agencies/{id} {
      allow read: if isSuperAdmin() || (isSignedIn() && myAgencyId() == id);
      allow write: if isSuperAdmin();
    }

    match /users/{uid} {
      allow read: if isSuperAdmin() || (isSignedIn() && (request.auth.uid == uid || isStaff(myAgencyId())));
      allow create: if isSuperAdmin() || (isSignedIn() && isValidUser(incoming()) && incoming().uid == uid);
      allow update: if isSuperAdmin() || (
        isSignedIn() && (
          (request.auth.uid == uid && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'phoneNumber', 'address', 'preferences', 'emergencyContact', 'updatedAt'])) ||
          (isAgencyAdmin(existing().agencyId) && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'updatedAt']))
        ) && isValidUser(incoming())
      );
    }

    match /packages/{packageId} {
      allow read: if true;
      allow write: if isSuperAdmin() || (isStaff(incoming().agencyId) && isValidPackage(incoming()));
    }

    match /bookings/{bookingId} {
      allow read: if isSuperAdmin() || (isSignedIn() && (resource.data.clientId == request.auth.uid || isStaff(resource.data.agencyId)));
      allow create: if isEmailVerified() && isValidBooking(incoming()) && incoming().agencyId == myAgencyId();
      allow update: if isSuperAdmin() || (
        isSignedIn() && (
          (resource.data.clientId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['notes', 'updatedAt'])) ||
          (isStaff(existing().agencyId) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'paidAmount', 'paymentStatus', 'updatedAt']))
        ) && isValidBooking(incoming())
      );
      allow delete: if isSuperAdmin() || isAgencyAdmin(existing().agencyId);
    }

    match /social_posts/{id} {
      allow read: if isSuperAdmin() || (isSignedIn() && isStaff(resource.data.agencyId));
      allow write: if isSuperAdmin() || (isSignedIn() && isStaff(incoming().agencyId));
    }

    match /audit_logs/{id} {
      allow read: if isSuperAdmin() || (isAgencyAdmin(resource.data.agencyId));
      allow create: if isSignedIn() && incoming().agencyId == myAgencyId() && incoming().userId == request.auth.uid;
    }

    match /coupons/{id} {
      allow read: if true;
      allow write: if isSuperAdmin() || isAgencyAdmin(incoming().agencyId);
    }

    match /documents/{id} {
      allow read: if isSuperAdmin() || (isSignedIn() && (resource.data.clientId == request.auth.uid || isStaff(resource.data.agencyId)));
      allow write: if isSuperAdmin() || (isSignedIn() && isStaff(incoming().agencyId));
    }

    match /tasks/{id} {
      allow read, write: if isSuperAdmin() || (isSignedIn() && isStaff(resource == null ? incoming().agencyId : resource.data.agencyId));
    }

    match /roles/{roleId} {
      allow read: if isSuperAdmin() || (isSignedIn() && myAgencyId() == resource.data.agencyId);
      allow create: if isSuperAdmin() || (isAgencyAdmin(incoming().agencyId) && isValidRole(incoming()));
      allow update: if isSuperAdmin() || (isAgencyAdmin(existing().agencyId) && isValidRole(incoming()));
      allow delete: if isSuperAdmin() || (isAgencyAdmin(existing().agencyId) && !existing().isSystem);
    }

    // Generic fallback for other identified collections in blueprint
    match /site_settings/{id} { allow read: if true; allow write: if isSuperAdmin() || isAgencyAdmin(incoming().agencyId); }
    match /custom_forms/{id} { allow read: if true; allow write: if isSuperAdmin() || isStaff(incoming().agencyId); }
    match /popup_campaigns/{id} { allow read: if true; allow write: if isSuperAdmin() || isStaff(incoming().agencyId); }
    match /services/{id} { allow read: if true; allow write: if isSuperAdmin() || isStaff(incoming().agencyId); }
    match /reviews/{id} { allow read: if true; allow write: if isSuperAdmin() || isStaff(incoming().agencyId); }
    match /faqs/{id} { allow read: if true; allow write: if isSuperAdmin() || isStaff(incoming().agencyId); }
    match /pages/{id} { allow read: if true; allow write: if isSuperAdmin() || isStaff(incoming().agencyId); }
    match /menus/{id} { allow read: if true; allow write: if isSuperAdmin() || isStaff(incoming().agencyId); }
    match /inventions/{id} { allow read: if true; allow write: if isSuperAdmin() || isStaff(incoming().agencyId); }
    match /themes/{id} { allow read: if true; allow write: if isSuperAdmin() || isStaff(incoming().agencyId); }
    
    match /itineraries/{id} {
      allow read: if isSuperAdmin() || (isSignedIn() && (resource.data.clientId == request.auth.uid || isStaff(resource.data.agencyId)));
      allow write: if isSuperAdmin() || isStaff(incoming().agencyId);
    }
    match /calendar_events/{id} {
      allow read: if isSuperAdmin() || (isSignedIn() && isStaff(resource.data.agencyId));
      allow write: if isSuperAdmin() || (isSignedIn() && isStaff(incoming().agencyId));
    }
    match /accommodations/{id} {
      allow read: if isSuperAdmin() || (isSignedIn() && isStaff(resource.data.agencyId));
      allow write: if isSuperAdmin() || (isSignedIn() && isStaff(incoming().agencyId));
    }
    match /transport/{id} {
      allow read: if isSuperAdmin() || (isSignedIn() && isStaff(resource.data.agencyId));
      allow write: if isSuperAdmin() || (isSignedIn() && isStaff(incoming().agencyId));
    }
    match /subscribers/{id} {
      allow read: if isSuperAdmin() || (isSignedIn() && isStaff(resource.data.agencyId));
      allow write: if isSuperAdmin() || (isSignedIn() && isStaff(incoming().agencyId));
    }
    match /messages/{id} {
      allow read: if isSuperAdmin() || (isSignedIn() && isStaff(resource.data.agencyId));
      allow write: if isSuperAdmin() || (isSignedIn() && isStaff(incoming().agencyId));
    }
    match /invoices/{id} {
      allow read: if isSuperAdmin() || (isSignedIn() && (resource.data.clientId == request.auth.uid || isStaff(resource.data.agencyId)));
      allow write: if isSuperAdmin() || (isSignedIn() && isStaff(incoming().agencyId));
    }
    match /wp_posts/{id} {
      allow read: if true;
      allow write: if isSuperAdmin() || isStaff(incoming().agencyId);
    }
    match /social_accounts/{id} {
      allow read: if isSuperAdmin() || (isSignedIn() && isStaff(resource.data.agencyId));
      allow write: if isSuperAdmin() || (isSignedIn() && isStaff(incoming().agencyId));
    }
    match /vlogs/{id} {
      allow read: if true;
      allow write: if isSuperAdmin() || (isSignedIn() && isStaff(incoming().agencyId));
    }

    // ===============================================================
    // 5. Master Deny-All Safety Net (Fallback)
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
